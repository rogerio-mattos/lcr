msgstr "韓国語"

msgid "Edit resolution"
msgstr "解像度を編集"

msgid "Apply this resolution now"
msgstr "この解像度を今すぐ適用"

msgid "Remove saved resolution"
msgstr "保存済みの解像度を削除"

msgid "Remove saved resolution?"
msgstr "保存済みの解像度を削除しますか？"

msgid "Remove {details} from your saved resolutions?"
msgstr "保存済みの解像度から {details} を削除しますか？"

msgid "Remove"
msgstr "削除"

msgid "On startup"
msgstr "起動時"

msgid "Edit Resolution"
msgstr "解像度を編集"

msgid "Apply when the computer starts"
msgstr "コンピューター起動時に適用"

msgid "If enabled, this resolution is selected automatically after you log in or restart. If disabled, it remains saved and you choose when to use it."
msgstr "有効にすると、ログインまたは再起動後にこの解像度が自動的に選択されます。無効の場合は保存されたままとなり、使用するタイミングはご自身で選べます。"

msgid "Save Changes"
msgstr "変更を保存"

msgid "Save and Apply"
msgstr "保存して適用"

msgid "Cancel"
msgstr "キャンセル"

msgid "Failed to update resolution: {error}"
msgstr "解像度の更新に失敗しました: {error}"

msgid "Resolution {details} updated and applied."
msgstr "解像度 {details} を更新して適用しました。"

msgid "Resolution {details} updated."
msgstr "解像度 {details} を更新しました。"

msgid "Resolution already saved"
msgstr "解像度は既に保存されています"

msgid "{details} is already saved for monitor {output}."
msgstr "{details} はモニター {output} に既に保存されています。"

msgid "Apply saved"
msgstr "保存済みの解像度を適用"

msgid "Another saved resolution already uses these settings."
msgstr "別の保存済み解像度が既にこの設定を使用しています。"

msgid "OK"
msgstr "OK"

msgid "xrandr is not available."
msgstr "xrandr が利用できません。"

msgid "Supported resolutions"
msgstr "サポートされている解像度"

msgid "Modes reported by xrandr for {output}. TVs and some monitors only accept these — custom modes may fail."
msgstr "xrandr が {output} に報告したモードです。TV や一部のモニターはこれらのみ受け付け、カスタムモードは失敗することがあります。"

msgid "No modes reported for this display."
msgstr "このディスプレイに報告されたモードはありません。"

msgid "{resolution} — {rates} Hz"
msgstr "{resolution} — {rates} Hz"

msgid " (active: {rate:g} Hz)"
msgstr "（使用中: {rate:g} Hz）"

msgid "{rates} Hz"
msgstr "{rates} Hz"

msgid " · active: {rate:g} Hz"
msgstr " · 使用中: {rate:g} Hz"

msgid "Use"
msgstr "使用"

msgid "Close"
msgstr "閉じる"

msgid "Apply now"
msgstr "今すぐ適用"

msgid "Fill form fields"
msgstr "フォームに入力"

msgid "Current"
msgstr "使用中"

msgid "Tip: use ▶ to apply a mode now. Use the copy button to fill the form."
msgstr "ヒント: ▶ でモードを今すぐ適用。コピーボタンでフォームに入力。"

msgid "({count} supported modes)"
msgstr "（{count} 件のサポートモード）"

msgid "Fields filled with {details}."
msgstr "フォームに {details} を入力しました。"

msgid "Saved resolutions for {output}"
msgstr "保存済み解像度 — {output}"

msgid "No saved resolutions for this monitor."
msgstr "このモニターに保存された解像度はありません。"

msgid "Added and applied."
msgstr "追加して適用しました。"

msgid "Added to the system."
msgstr "システムに追加しました。"

msgid "Applied."
msgstr "適用しました。"

msgid "Updated and applied."
msgstr "更新して適用しました。"

msgid "Updated."
msgstr "更新しました。"

