msgid "Edit resolution"
msgstr "تعديل الدقة"

msgid "Apply this resolution now"
msgstr "تطبيق هذه الدقة الآن"

msgid "Remove saved resolution"
msgstr "إزالة الدقة المحفوظة"

msgid "Remove saved resolution?"
msgstr "إزالة الدقة المحفوظة؟"

msgid "Remove {details} from your saved resolutions?"
msgstr "إزالة {details} من الدقات المحفوظة؟"

msgid "Remove"
msgstr "إزالة"

msgid "On startup"
msgstr "عند بدء التشغيل"

msgid "Edit Resolution"
msgstr "تعديل الدقة"

msgid "Apply when the computer starts"
msgstr "تطبيق عند بدء تشغيل الحاسوب"

msgid "If enabled, this resolution is selected automatically after you log in or restart. If disabled, it remains saved and you choose when to use it."
msgstr "إذا كان مفعّلاً، تُختار هذه الدقة تلقائياً بعد تسجيل الدخول أو إعادة التشغيل. إذا كان معطّلاً، تبقى محفوظة وتختار متى تستخدمها."

msgid "Save Changes"
msgstr "حفظ التغييرات"

msgid "Save and Apply"
msgstr "حفظ وتطبيق"

msgid "Cancel"
msgstr "إلغاء"

msgid "Failed to update resolution: {error}"
msgstr "فشل تحديث الدقة: {error}"

msgid "Resolution {details} updated and applied."
msgstr "تم تحديث الدقة {details} وتطبيقها."

msgid "Resolution {details} updated."
msgstr "تم تحديث الدقة {details}."

msgid "Resolution already saved"
msgstr "الدقة محفوظة بالفعل"

msgid "{details} is already saved for monitor {output}."
msgstr "{details} محفوظة بالفعل للشاشة {output}."

msgid "Apply saved"
msgstr "تطبيق الدقة المحفوظة"

msgid "Another saved resolution already uses these settings."
msgstr "دقة محفوظة أخرى تستخدم هذه الإعدادات بالفعل."

msgid "OK"
msgstr "موافق"

msgid "xrandr is not available."
msgstr "xrandr غير متاح."

msgid "Supported resolutions"
msgstr "الدقات المدعومة"

msgid "Modes reported by xrandr for {output}. TVs and some monitors only accept these — custom modes may fail."
msgstr "أوضاع xrandr لـ {output}. تدعم التلفزيات وبعض الشاشات هذه فقط — قد تفشل الأوضاع المخصصة."

msgid "No modes reported for this display."
msgstr "لا توجد أوضاع مُبلّغ عنها لهذه الشاشة."

msgid "{resolution} — {rates} Hz"
msgstr "{resolution} — {rates} Hz"

msgid " (active: {rate:g} Hz)"
msgstr " (نشط: {rate:g} Hz)"

msgid "{rates} Hz"
msgstr "{rates} Hz"

msgid " · active: {rate:g} Hz"
msgstr " · نشط: {rate:g} Hz"

msgid "Use"
msgstr "استخدام"

msgid "Close"
msgstr "إغلاق"

msgid "Apply now"
msgstr "تطبيق الآن"

msgid "Fill form fields"
msgstr "ملء النموذج"

msgid "Current"
msgstr "الحالي"

msgid "Tip: use ▶ to apply a mode now. Use the copy button to fill the form."
msgstr "نصيحة: استخدم ▶ لتطبيق الوضع الآن. استخدم زر النسخ لملء النموذج."

msgid "({count} supported modes)"
msgstr "({count} أوضاع مدعومة)"

msgid "Fields filled with {details}."
msgstr "تم ملء الحقول بـ {details}."

msgid "Saved resolutions for {output}"
msgstr "الدقات المحفوظة — {output}"

msgid "No saved resolutions for this monitor."
msgstr "لا توجد دقات محفوظة لهذه الشاشة."

msgid "Added and applied."
msgstr "تمت الإضافة والتطبيق."

msgid "Added to the system."
msgstr "تمت الإضافة إلى النظام."

msgid "Applied."
msgstr "تم التطبيق."

msgid "Updated and applied."
msgstr "تم التحديث والتطبيق."

msgid "Updated."
msgstr "تم التحديث."

msgid "Removed."
msgstr "تمت الإزالة."

msgid "Fields filled."
msgstr "تم ملء النموذج."
