msgid "Linux Custom Resolution"
msgstr "Linux Custom Resolution"

msgid "Refresh monitors"
msgstr "تحديث الشاشات"

msgid "Wayland session detected. LCR uses xrandr (X11) and works best on X11 sessions or when the compositor exposes XWayland."
msgstr "تم اكتشاف جلسة Wayland. يستخدم LCR أداة xrandr (X11) ويعمل بشكل أفضل في جلسات X11 أو عندما يوفّر المُجمِّع XWayland."

msgid "xrandr is not available. Install xorg-xrandr on your system."
msgstr "xrandr غير متاح. ثبّت الحزمة xorg-xrandr على نظامك."

msgid "New Resolution"
msgstr "دقة جديدة"

msgid "Monitor"
msgstr "الشاشة"

msgid "Width"
msgstr "العرض"

msgid "Height"
msgstr "الارتفاع"

msgid "Refresh Rate (Hz)"
msgstr "معدل التحديث (هرتز)"

msgid "Add to System"
msgstr "إضافة إلى النظام"

msgid "Add and Apply"
msgstr "إضافة وتطبيق"

msgid "Restore default"
msgstr "استعادة الافتراضي"

msgid "Monitor {output} restored to default resolution."
msgstr "تمت استعادة الشاشة {output} إلى الدقة الافتراضية."

msgid "Saved Resolutions"
msgstr "الدقات المحفوظة"

msgid "No saved resolutions yet."
msgstr "لا توجد دقات محفوظة."

msgid "No connected monitor found."
msgstr "لم يتم العثور على شاشة متصلة."

msgid "No monitor"
msgstr "لا توجد شاشة"

msgid "Select a valid monitor."
msgstr "اختر شاشة صالحة."

msgid "Resolution {details} added and applied."
msgstr "تمت إضافة الدقة {details} وتطبيقها."

msgid "Resolution {details} added to the system."
msgstr "تمت إضافة الدقة {details} إلى النظام."

msgid "Resolution {details} applied."
msgstr "تم تطبيق الدقة {details}."

msgid "Resolution not found."
msgstr "الدقة غير موجودة."

msgid "Removed from profile, but xrandr failed: {error}"
msgstr "أُزيلت من الملف الشخصي، لكن xrandr فشل: {error}"

msgid "Removed {details}."
msgstr "تمت إزالة {details}."

msgid "Applied on startup"
msgstr "تُطبَّق عند بدء التشغيل"

msgid "Manual use"
msgstr "استخدام يدوي"

msgid "Language"
msgstr "اللغة"

msgid "System Default"
msgstr "افتراضي النظام"

