msgid "Linux Custom Resolution"
msgstr "Linux Custom Resolution"

msgid "Refresh monitors"
msgstr "모니터 새로고침"

msgid "Wayland session detected. LCR uses xrandr (X11) and works best on X11 sessions or when the compositor exposes XWayland."
msgstr "Wayland 세션이 감지되었습니다. LCR은 xrandr(X11)을 사용하며 X11 세션이나 컴포지터가 XWayland를 제공할 때 가장 잘 작동합니다."

msgid "xrandr is not available. Install xorg-xrandr on your system."
msgstr "xrandr을 사용할 수 없습니다. 시스템에 xorg-xrandr을 설치하세요."

msgid "New Resolution"
msgstr "새 해상도"

msgid "Monitor"
msgstr "모니터"

msgid "Width"
msgstr "너비"

msgid "Height"
msgstr "높이"

msgid "Refresh Rate (Hz)"
msgstr "주사율 (Hz)"

msgid "Add to System"
msgstr "시스템에 추가"

msgid "Add and Apply"
msgstr "추가 및 적용"

msgid "Restore default"
msgstr "기본값 복원"

msgid "Monitor {output} restored to default resolution."
msgstr "모니터 {output}이(가) 기본 해상도로 복원되었습니다."

msgid "Saved Resolutions"
msgstr "저장된 해상도"

msgid "No saved resolutions yet."
msgstr "저장된 해상도가 없습니다."

msgid "No connected monitor found."
msgstr "연결된 모니터를 찾을 수 없습니다."

msgid "No monitor"
msgstr "모니터 없음"

msgid "Select a valid monitor."
msgstr "유효한 모니터를 선택하세요."

msgid "Resolution {details} added and applied."
msgstr "해상도 {details}이(가) 추가되어 적용되었습니다."

msgid "Resolution {details} added to the system."
msgstr "해상도 {details}이(가) 시스템에 추가되었습니다."

msgid "Resolution {details} applied."
msgstr "해상도 {details}이(가) 적용되었습니다."

msgid "Resolution not found."
msgstr "해상도를 찾을 수 없습니다."

msgid "Removed from profile, but xrandr failed: {error}"
msgstr "프로필에서 제거되었지만 xrandr이 실패했습니다: {error}"

msgid "Removed {details}."
msgstr "해상도 {details}이(가) 제거되었습니다."

msgid "Applied on startup"
msgstr "시작 시 적용"

msgid "Manual use"
msgstr "수동 사용"

msgid "Language"
msgstr "언어"

msgid "System Default"
msgstr "시스템 기본값"

msgid "English"
msgstr "영어"

msgid "Portuguese (Brazil)"
msgstr "포르투갈어 (브라질)"

msgid "Spanish"
msgstr "스페인어"

msgid "Russian"
msgstr "러시아어"

msgid "Chinese (Simplified)"
msgstr "중국어 (간체)"

msgid "Chinese (Traditional)"
msgstr "중국어 (번체)"

msgid "French"
msgstr "프랑스어"

msgid "German"
msgstr "독일어"

msgid "Japanese"
msgstr "일본어"

msgid "Arabic"
msgstr "아랍어"

msgid "Hindi"
msgstr "힌디어"

msgid "Italian"
msgstr "이탈리아어"

msgid "Korean"
msgstr "한국어"

msgid "Edit resolution"
msgstr "해상도 편집"

msgid "Apply this resolution now"
msgstr "지금 이 해상도 적용"

msgid "Remove saved resolution"
msgstr "저장된 해상도 제거"

msgid "Remove saved resolution?"
msgstr "저장된 해상도를 제거할까요?"

msgid "Remove {details} from your saved resolutions?"
msgstr "저장된 해상도에서 {details}을(를) 제거할까요?"

msgid "Remove"
msgstr "제거"

msgid "On startup"
msgstr "시작 시"

msgid "Edit Resolution"
msgstr "해상도 편집"

msgid "Apply when the computer starts"
msgstr "컴퓨터 시작 시 적용"

msgid "If enabled, this resolution is selected automatically after you log in or restart. If disabled, it remains saved and you choose when to use it."
msgstr "활성화하면 로그인 또는 재시작 후 이 해상도가 자동으로 선택됩니다. 비활성화하면 저장된 상태로 유지되며 사용 시점을 직접 선택합니다."

msgid "Save Changes"
msgstr "변경 사항 저장"

msgid "Save and Apply"
msgstr "저장 및 적용"

msgid "Cancel"
msgstr "취소"

msgid "Failed to update resolution: {error}"
msgstr "해상도 업데이트 실패: {error}"

msgid "Resolution {details} updated and applied."
msgstr "해상도 {details}이(가) 업데이트되어 적용되었습니다."

msgid "Resolution {details} updated."
msgstr "해상도 {details}이(가) 업데이트되었습니다."

msgid "Resolution already saved"
msgstr "이미 저장된 해상도"

msgid "{details} is already saved for monitor {output}."
msgstr "{details}은(는) 모니터 {output}에 이미 저장되어 있습니다."

msgid "Apply saved"
msgstr "저장된 해상도 적용"

msgid "Another saved resolution already uses these settings."
msgstr "다른 저장된 해상도가 이미 이 설정을 사용 중입니다."

msgid "OK"
msgstr "확인"

msgid "xrandr is not available."
msgstr "xrandr을 사용할 수 없습니다."

msgid "Supported resolutions"
msgstr "지원되는 해상도"

msgid "Modes reported by xrandr for {output}. TVs and some monitors only accept these — custom modes may fail."
msgstr "xrandr가 {output}에 대해 보고한 모드입니다. TV와 일부 모니터는 이 모드만 허용하며 사용자 지정 모드는 실패할 수 있습니다."

msgid "No modes reported for this display."
msgstr "이 디스플레이에 보고된 모드가 없습니다."

msgid "{resolution} — {rates} Hz"
msgstr "{resolution} — {rates} Hz"

msgid " (active: {rate:g} Hz)"
msgstr " (활성: {rate:g} Hz)"

msgid "{rates} Hz"
msgstr "{rates} Hz"

msgid " · active: {rate:g} Hz"
msgstr " · 활성: {rate:g} Hz"

msgid "Use"
msgstr "사용"

msgid "Close"
msgstr "닫기"

msgid "Apply now"
msgstr "지금 적용"

msgid "Fill form fields"
msgstr "양식 채우기"

msgid "Current"
msgstr "현재"

msgid "Tip: use ▶ to apply a mode now. Use the copy button to fill the form."
msgstr "팁: ▶로 지금 모드를 적용하세요. 복사 버튼으로 양식을 채우세요."

msgid "({count} supported modes)"
msgstr "({count}개 지원 모드)"

msgid "Fields filled with {details}."
msgstr "양식이 {details}(으)로 채워졌습니다."

msgid "Saved resolutions for {output}"
msgstr "저장된 해상도 — {output}"

msgid "No saved resolutions for this monitor."
msgstr "이 모니터에 저장된 해상도가 없습니다."

msgid "Added and applied."
msgstr "추가 및 적용됨."

msgid "Added to the system."
msgstr "시스템에 추가됨."

msgid "Applied."
msgstr "적용됨."

msgid "Updated and applied."
msgstr "업데이트 및 적용됨."

msgid "Updated."
msgstr "업데이트됨."

msgid "Removed."
msgstr "제거됨."

msgid "Fields filled."
msgstr "양식 채움."
