msgstr "All'avvio"

msgid "Edit Resolution"
msgstr "Modifica risoluzione"

msgid "Apply when the computer starts"
msgstr "Applica all'avvio del computer"

msgid "If enabled, this resolution is selected automatically after you log in or restart. If disabled, it remains saved and you choose when to use it."
msgstr "Se abilitata, questa risoluzione viene selezionata automaticamente dopo l'accesso o il riavvio. Se disabilitata, resta salvata e scegli tu quando usarla."

msgid "Save Changes"
msgstr "Salva modifiche"

msgid "Save and Apply"
msgstr "Salva e applica"

msgid "Cancel"
msgstr "Annulla"

msgid "Failed to update resolution: {error}"
msgstr "Impossibile aggiornare la risoluzione: {error}"

msgid "Resolution {details} updated and applied."
msgstr "Risoluzione {details} aggiornata e applicata."

msgid "Resolution {details} updated."
msgstr "Risoluzione {details} aggiornata."

msgid "Resolution already saved"
msgstr "Risoluzione già salvata"

msgid "{details} is already saved for monitor {output}."
msgstr "{details} è già salvata per il monitor {output}."

msgid "Apply saved"
msgstr "Applica risoluzione salvata"

msgid "Another saved resolution already uses these settings."
msgstr "Un'altra risoluzione salvata usa già queste impostazioni."

msgid "OK"
msgstr "OK"

msgid "xrandr is not available."
msgstr "xrandr non è disponibile."

msgid "Supported resolutions"
msgstr "Risoluzioni supportate"

msgid "Modes reported by xrandr for {output}. TVs and some monitors only accept these — custom modes may fail."
msgstr "Modalità segnalate da xrandr per {output}. TV e alcuni monitor accettano solo queste — le modalità personalizzate possono fallire."

msgid "No modes reported for this display."
msgstr "Nessuna modalità segnalata per questo schermo."

