msgid "Linux Custom Resolution"
msgstr "Linux Custom Resolution"

msgid "Refresh monitors"
msgstr "Aggiorna monitor"

msgid "Wayland session detected. LCR uses xrandr (X11) and works best on X11 sessions or when the compositor exposes XWayland."
msgstr "Sessione Wayland rilevata. LCR usa xrandr (X11) e funziona meglio in sessioni X11 o quando il compositor espone XWayland."

msgid "xrandr is not available. Install xorg-xrandr on your system."
msgstr "xrandr non è disponibile. Installa xorg-xrandr sul sistema."

msgid "New Resolution"
msgstr "Nuova risoluzione"

msgid "Monitor"
msgstr "Monitor"

msgid "Width"
msgstr "Larghezza"

msgid "Height"
msgstr "Altezza"

