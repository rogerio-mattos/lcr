msgstr "Aggiungi al sistema"

msgid "Add and Apply"
msgstr "Aggiungi e applica"

msgid "Restore default"
msgstr "Ripristina predefinito"

msgid "Monitor {output} restored to default resolution."
msgstr "Monitor {output} ripristinato alla risoluzione predefinita."

msgid "Saved Resolutions"
msgstr "Risoluzioni salvate"

msgid "No saved resolutions yet."
msgstr "Nessuna risoluzione salvata."

msgid "No connected monitor found."
msgstr "Nessun monitor connesso trovato."

msgid "No monitor"
msgstr "Nessun monitor"

msgid "Select a valid monitor."
msgstr "Seleziona un monitor valido."

msgid "Resolution {details} added and applied."
msgstr "Risoluzione {details} aggiunta e applicata."

