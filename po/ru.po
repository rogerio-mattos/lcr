msgstr "Корейский"

msgid "Edit resolution"
msgstr "Изменить разрешение"

msgid "Apply this resolution now"
msgstr "Применить это разрешение сейчас"

msgid "Remove saved resolution"
msgstr "Удалить сохранённое разрешение"

msgid "Remove saved resolution?"
msgstr "Удалить сохранённое разрешение?"

msgid "Remove {details} from your saved resolutions?"
msgstr "Удалить {details} из сохранённых разрешений?"

msgid "Remove"
msgstr "Удалить"

msgid "On startup"
msgstr "При запуске"

msgid "Edit Resolution"
msgstr "Изменить разрешение"

msgid "Apply when the computer starts"
msgstr "Применять при запуске компьютера"

msgid "If enabled, this resolution is selected automatically after you log in or restart. If disabled, it remains saved and you choose when to use it."
msgstr "Если включено, это разрешение выбирается автоматически после входа или перезагрузки. Если выключено, оно остаётся сохранённым, и вы сами выбираете, когда его использовать."

msgid "Save Changes"
msgstr "Сохранить изменения"

msgid "Save and Apply"
msgstr "Сохранить и применить"

msgid "Cancel"
msgstr "Отмена"

msgid "Failed to update resolution: {error}"
msgstr "Не удалось обновить разрешение: {error}"

msgid "Resolution {details} updated and applied."
msgstr "Разрешение {details} обновлено и применено."

msgid "Resolution {details} updated."
msgstr "Разрешение {details} обновлено."

msgid "Resolution already saved"
msgstr "Разрешение уже сохранено"

msgid "{details} is already saved for monitor {output}."
msgstr "{details} уже сохранено для монитора {output}."

msgid "Apply saved"
msgstr "Применить сохранённое"

msgid "Another saved resolution already uses these settings."
msgstr "Другая сохранённая конфигурация уже использует эти параметры."

msgid "OK"
msgstr "ОК"

msgid "xrandr is not available."
msgstr "xrandr недоступен."

msgid "Supported resolutions"
msgstr "Поддерживаемые разрешения"

msgid "Modes reported by xrandr for {output}. TVs and some monitors only accept these — custom modes may fail."
msgstr "Режимы xrandr для {output}. Телевизоры и некоторые мониторы принимают только их — пользовательские режимы могут не работать."

msgid "No modes reported for this display."
msgstr "Для этого экрана режимы не сообщены."

msgid "{resolution} — {rates} Hz"
msgstr "{resolution} — {rates} Гц"

msgid " (active: {rate:g} Hz)"
msgstr " (активно: {rate:g} Гц)"

msgid "{rates} Hz"
msgstr "{rates} Гц"

msgid " · active: {rate:g} Hz"
msgstr " · активно: {rate:g} Гц"

msgid "Use"
msgstr "Использовать"

msgid "Close"
msgstr "Закрыть"

msgid "Apply now"
msgstr "Применить сейчас"

msgid "Fill form fields"
msgstr "Заполнить форму"

msgid "Current"
msgstr "Текущая"

msgid "Tip: use ▶ to apply a mode now. Use the copy button to fill the form."
msgstr "Подсказка: нажмите ▶, чтобы применить режим. Кнопка копирования заполнит форму."

msgid "({count} supported modes)"
msgstr "({count} поддерживаемых режимов)"

msgid "Fields filled with {details}."
msgstr "Поля заполнены: {details}."

msgid "Saved resolutions for {output}"
msgstr "Сохранённые разрешения — {output}"

msgid "No saved resolutions for this monitor."
msgstr "Нет сохранённых разрешений для этого монитора."

msgid "Added and applied."
msgstr "Добавлено и применено."

msgid "Added to the system."
msgstr "Добавлено в систему."

msgid "Applied."
msgstr "Применено."

msgid "Updated and applied."
msgstr "Обновлено и применено."

msgid "Updated."
msgstr "Обновлено."

