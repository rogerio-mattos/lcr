msgid "Linux Custom Resolution"
msgstr "Linux Custom Resolution"

msgid "Refresh monitors"
msgstr "Обновить мониторы"

msgid "Wayland session detected. LCR uses xrandr (X11) and works best on X11 sessions or when the compositor exposes XWayland."
msgstr "Обнаружена сессия Wayland. LCR использует xrandr (X11) и лучше всего работает в сессиях X11 или когда композитор предоставляет XWayland."

msgid "xrandr is not available. Install xorg-xrandr on your system."
msgstr "xrandr недоступен. Установите пакет xorg-xrandr в системе."

msgid "New Resolution"
msgstr "Новое разрешение"

msgid "Monitor"
msgstr "Монитор"

msgid "Width"
msgstr "Ширина"

msgid "Height"
msgstr "Высота"

msgid "Refresh Rate (Hz)"
msgstr "Частота (Гц)"

msgid "Add to System"
msgstr "Добавить в систему"

msgid "Add and Apply"
msgstr "Добавить и применить"

msgid "Restore default"
msgstr "Восстановить стандарт"

msgid "Monitor {output} restored to default resolution."
msgstr "Монитор {output} восстановлен до стандартного разрешения."

msgid "Saved Resolutions"
msgstr "Сохранённые разрешения"

msgid "No saved resolutions yet."
msgstr "Нет сохранённых разрешений."

msgid "No connected monitor found."
msgstr "Подключённые мониторы не найдены."

msgid "No monitor"
msgstr "Нет монитора"

msgid "Select a valid monitor."
msgstr "Выберите действительный монитор."

msgid "Resolution {details} added and applied."
msgstr "Разрешение {details} добавлено и применено."

msgid "Resolution {details} added to the system."
msgstr "Разрешение {details} добавлено в систему."

msgid "Resolution {details} applied."
msgstr "Разрешение {details} применено."

msgid "Resolution not found."
msgstr "Разрешение не найдено."

msgid "Removed from profile, but xrandr failed: {error}"
msgstr "Удалено из профиля, но xrandr завершился с ошибкой: {error}"

msgid "Removed {details}."
msgstr "Разрешение {details} удалено."

msgid "Applied on startup"
msgstr "Применяется при запуске"

msgid "Manual use"
msgstr "Ручное использование"

msgid "Language"
msgstr "Язык"

msgid "System Default"
msgstr "По умолчанию в системе"

msgid "English"
msgstr "Английский"

msgid "Portuguese (Brazil)"
msgstr "Португальский (Бразилия)"

