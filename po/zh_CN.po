msgid "Linux Custom Resolution"
msgstr "Linux Custom Resolution"

msgid "Refresh monitors"
msgstr "刷新显示器"

msgid "Wayland session detected. LCR uses xrandr (X11) and works best on X11 sessions or when the compositor exposes XWayland."
msgstr "检测到 Wayland 会话。LCR 使用 xrandr (X11)，在 X11 会话或合成器提供 XWayland 时效果最佳。"

msgid "xrandr is not available. Install xorg-xrandr on your system."
msgstr "xrandr 不可用。请在系统上安装 xorg-xrandr。"

msgid "New Resolution"
msgstr "新分辨率"

msgid "Monitor"
msgstr "显示器"

msgid "Width"
msgstr "宽度"

msgid "Height"
msgstr "高度"

msgid "Refresh Rate (Hz)"
msgstr "刷新率 (Hz)"

msgid "Add to System"
msgstr "添加到系统"

msgid "Add and Apply"
msgstr "添加并应用"

msgid "Restore default"
msgstr "恢复默认"

msgid "Monitor {output} restored to default resolution."
msgstr "显示器 {output} 已恢复为默认分辨率。"

msgid "Saved Resolutions"
msgstr "已保存的分辨率"

msgid "No saved resolutions yet."
msgstr "尚无已保存的分辨率。"

msgid "No connected monitor found."
msgstr "未找到已连接的显示器。"

msgid "No monitor"
msgstr "无显示器"

msgid "Select a valid monitor."
msgstr "请选择有效的显示器。"

msgid "Resolution {details} added and applied."
msgstr "分辨率 {details} 已添加并应用。"

msgid "Resolution {details} added to the system."
msgstr "分辨率 {details} 已添加到系统。"

msgid "Resolution {details} applied."
msgstr "分辨率 {details} 已应用。"

msgid "Resolution not found."
msgstr "未找到分辨率。"

msgid "Removed from profile, but xrandr failed: {error}"
msgstr "已从配置文件中移除，但 xrandr 失败：{error}"

msgid "Removed {details}."
msgstr "已移除 {details}。"

msgid "Applied on startup"
msgstr "启动时应用"

msgid "Manual use"
msgstr "手动使用"

